# Database (Vercel Postgres / Neon / Supabase — serverless Postgres URL)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Prisma "directUrl" — if omitted, npm scripts default it to DATABASE_URL (see scripts/prisma-with-direct-url.cjs).
# Neon: use the pooled URL above and put the non-pooler (direct) connection string here to avoid P1017 on db push.
# DATABASE_DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Auth (generate with: openssl rand -base64 32)
AUTH_SECRET="your-auth-secret"

# Admin login (optional). If set, /admin requires this password. If not set, /admin is open.
ADMIN_PASSWORD=""

# Stripe (fiat payments) — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Crypto payments — pick one provider
# Coinbase Commerce — https://commerce.coinbase.com/
# Webhook POST /api/webhooks/crypto with header x-provider: coinbase_commerce (default).
# Put invoiceId (and optional amountCents) in charge metadata when you create the charge.
COINBASE_COMMERCE_WEBHOOK_SECRET=""
COINBASE_COMMERCE_API_KEY=""

# Or NOWPayments — https://nowpayments.io/
# IPN callback URL: https://your-domain/api/webhooks/crypto (NOWPayments sends x-nowpayments-sig; no x-provider needed).
# In Dashboard → Payment settings, create an IPN secret and paste here.
# When you create a payment via API, set order_id to the Invoice id from this app (Admin → Invoices).
# NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""

# App URL (for webhooks and redirects; set in Vercel to your domain)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
